{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": [
        "TTCTL_E2E",
        "TTCTL_UPDATE_WIRE_SNAPSHOTS",
        "TTCTL_CONFIG_FILE",
        "XDG_CONFIG_HOME",
        "HOME",
        "OP_ACCOUNT",
        "OP_SERVICE_ACCOUNT_TOKEN",
        "OP_SESSION_*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
