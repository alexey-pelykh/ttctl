{
  "name": "@ttctl/e2e",
  "version": "0.0.0",
  "description": "E2E tests for TTCtl against live Toptal Talent platform",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only",
  "author": "Alexey Pelykh (https://github.com/alexey-pelykh)",
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "vitest run --config ../../vitest.e2e.config.ts --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@ttctl/cli": "workspace:^",
    "@ttctl/core": "workspace:^",
    "@ttctl/mcp": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
