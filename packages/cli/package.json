{
  "name": "@ttctl/cli",
  "version": "0.0.0",
  "description": "TTCtl CLI commands and program definition",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "AGPL-3.0-only",
  "author": "Alexey Pelykh (https://github.com/alexey-pelykh)",
  "homepage": "https://github.com/alexey-pelykh/ttctl/tree/main/packages/cli",
  "bugs": "https://github.com/alexey-pelykh/ttctl/issues",
  "funding": "https://github.com/sponsors/alexey-pelykh",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexey-pelykh/ttctl.git",
    "directory": "packages/cli"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "THIRD-PARTY-NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "cp ../../LICENSE ../../THIRD-PARTY-NOTICES.md .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@ttctl/core": "workspace:^",
    "cli-table3": "catalog:",
    "commander": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  }
}
