{
  "name": "ttctl-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "turbo run test:e2e --concurrency=1",
    "test:e2e:crash-recovery": "pnpm --filter @ttctl/e2e test:e2e:crash-recovery",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm format:check && turbo run lint && pnpm lint:root && pnpm check-secret-leakage && pnpm check-e2e-coverage && pnpm check-surface-coverage && pnpm check-dep-confusion && pnpm check-write-read-symmetry && pnpm check-merge-completeness && pnpm check-snapshot-degeneracy && pnpm check-readme-verbs && pnpm check-scalar-type-consistency",
    "lint:root": "eslint eslint.config.js vitest.config.ts vitest.e2e.config.ts codegen.config.ts scripts/",
    "license-check": "node scripts/check-licenses.js",
    "check-secret-leakage": "tsx scripts/check-secret-leakage.ts",
    "check-e2e-coverage": "tsx scripts/check-e2e-coverage.ts",
    "check-surface-coverage": "tsx scripts/check-surface-coverage.ts",
    "check-dep-confusion": "tsx scripts/check-dep-confusion.ts",
    "check-write-read-symmetry": "tsx scripts/check-write-read-symmetry.ts",
    "check-merge-completeness": "tsx scripts/check-merge-completeness.ts",
    "check-snapshot-degeneracy": "tsx scripts/check-snapshot-degeneracy.ts --strict",
    "check-readme-verbs": "tsx scripts/check-readme-verbs.ts --strict",
    "check-scalar-type-consistency": "tsx scripts/check-scalar-type-consistency.ts",
    "codegen": "graphql-codegen --config codegen.config.ts",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@graphql-codegen/add": "catalog:",
    "@graphql-codegen/cli": "catalog:",
    "@tony.ganchev/eslint-plugin-header": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "graphql": "catalog:",
    "graphql-codegen-typescript-validation-schema": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
